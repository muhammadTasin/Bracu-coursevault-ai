# Supabase Keys (Publicly exposed in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# AI Provider API Keys (Used ONLY in the secure Next.js backend/server actions)
# Gemini API Key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key

# OpenRouter API Key (Used as a fallback provider)
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional Site URL for custom callback routing (e.g. https://yourdomain.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

